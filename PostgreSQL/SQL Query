Total Records

SELECT COUNT(*)
FROM retail;

-- Missing Customer IDs

SELECT COUNT(*)
FROM retail
WHERE customer_id IS NULL;

-- Missing Product Descriptions

SELECT COUNT(*)
FROM retail
WHERE description IS NULL;

-- Total Revenue, Orders and Customers

SELECT
SUM(revenue) AS total_revenue,
COUNT(DISTINCT invoice) AS total_orders,
COUNT(DISTINCT customer_id) AS total_customers,
ROUND(
SUM(revenue) / COUNT(DISTINCT invoice),
2
) AS average_order_value
FROM retail
WHERE customer_id IS NOT NULL;

-- Monthly Revenue Trend

SELECT
EXTRACT(YEAR FROM invoice_date) AS year,
EXTRACT(MONTH FROM invoice_date) AS month,
SUM(revenue) AS monthly_revenue
FROM retail
GROUP BY year, month
ORDER BY year, month;

-- Top Revenue Generating Products

SELECT
description,
SUM(revenue) AS total_revenue
FROM retail
GROUP BY description
ORDER BY total_revenue DESC
LIMIT 10;

-- Top Selling Products By Quantity

SELECT
description,
SUM(quantity) AS total_quantity_sold
FROM retail
GROUP BY description
ORDER BY total_quantity_sold DESC
LIMIT 10;

-- Product Revenue Ranking

SELECT
description,
SUM(revenue) AS total_revenue,
RANK() OVER (
ORDER BY SUM(revenue) DESC
) AS product_rank
FROM retail
GROUP BY description;

-- Top Customers By Revenue

SELECT
customer_id,
SUM(revenue) AS total_revenue
FROM retail
WHERE customer_id IS NOT NULL
GROUP BY customer_id
ORDER BY total_revenue DESC
LIMIT 10;

-- Customer Purchase Frequency

SELECT
customer_id,
COUNT(DISTINCT invoice) AS total_orders
FROM retail
WHERE customer_id IS NOT NULL
GROUP BY customer_id
ORDER BY total_orders DESC
LIMIT 10;

-- Customer Revenue & Order Analysis

SELECT
customer_id,
SUM(revenue) AS total_revenue,
COUNT(DISTINCT invoice) AS total_orders
FROM retail
WHERE customer_id IS NOT NULL
GROUP BY customer_id
ORDER BY total_revenue DESC;

-- Customer Segmentation

SELECT
customer_id,
SUM(revenue) AS total_revenue,
CASE
WHEN SUM(revenue) >= 10000 THEN 'Platinum'
WHEN SUM(revenue) >= 5000 THEN 'Gold'
WHEN SUM(revenue) >= 1000 THEN 'Silver'
ELSE 'Regular'
END AS customer_segment
FROM retail
WHERE customer_id IS NOT NULL
GROUP BY customer_id;

-- Revenue By Country

SELECT
country,
SUM(revenue) AS total_revenue
FROM retail
GROUP BY country
ORDER BY total_revenue DESC;

-- Customers By Country

SELECT
country,
COUNT(DISTINCT customer_id) AS total_customers
FROM retail
GROUP BY country
ORDER BY total_customers DESC;

-- Orders By Country

SELECT
country,
COUNT(DISTINCT invoice) AS total_orders
FROM retail
GROUP BY country
ORDER BY total_orders DESC;

-- High Value Customers (CTE)

WITH customer_revenue AS (
SELECT
customer_id,
SUM(revenue) AS total_revenue
FROM retail
WHERE customer_id IS NOT NULL
GROUP BY customer_id
)

SELECT *
FROM customer_revenue
WHERE total_revenue > 10000
ORDER BY total_revenue DESC;

-------------------------------------------------------------------------------
-------------------------------------------------------------------------------

1. United Kingdom generated the highest revenue.
2. Revenue peaked during November and December.
3. Regency Cake Stand 3 Tier was the highest revenue-generating product.
4. A small group of customers contributed a significant share of total revenue.
5. Customer purchasing behavior followed a Pareto-like distribution.
